# ============================================================
# ETL Environment Example
# ============================================================
# 1) GitHub credentials are read from this .env file.
#    Use EITHER GitHub App credentials OR a personal token.
# 2) Snowflake is read from Airflow Connection `snowflake_default`
#    (Airflow UI -> Admin -> Connections). It is NOT read from .env.

# GitHub (choose one method)
# Method A: GitHub App (recommended)
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_INSTALLATION_ID=your_github_app_installation_id
GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Method B: Personal Access Token fallback
# GITHUB_TOKEN=your_github_token_here

# Snowflake (set in Airflow Connection, not here)
# Connection id: snowflake_default
# Account hint format: XXXXXXX-XXX1234
# Example fields in Airflow connection:
# - Account: XXXXXXX-XXX1234
# - User: your_snowflake_username
# - Password: your_snowflake_password
# - Warehouse: COMPUTE_WH
# - Database: AIRFLOW_ML
# - Schema: RAW

# Airflow Configuration (for docker-compose)
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=change_me

# GCP/Vertex AI Configuration (optional, for GCS uploads)
# GCS_BUCKET=your_gcs_bucket
# GCS_PROJECT_ID=your_gcp_project_id
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional: OpenAI/Anthropic (future features)
# OPENAI_API_KEY=your_openai_key
# ANTHROPIC_API_KEY=your_anthropic_key
