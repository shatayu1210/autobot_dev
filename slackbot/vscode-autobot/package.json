{
  "name": "autobot-patcher",
  "displayName": "AutoBot Patcher",
  "description": "Planner → Patcher → Critic orchestration for GitHub issues with compact repo context (Tree-sitter–ready).",
  "version": "0.1.0",
  "publisher": "autobot",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onUri",
    "onCommand:autobot.openIssue",
    "onCommand:autobot.fetchIssue",
    "onCommand:autobot.runPlanner",
    "onCommand:autobot.runPatcher",
    "onCommand:autobot.runCritic",
    "onCommand:autobot.runPatchLoop",
    "onCommand:autobot.setGitHubToken",
    "onCommand:autobot.showRepoIndex",
    "onCommand:autobot.copyOpenLink",
    "onView:autobot.patchView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autobot.openIssue",
        "title": "AutoBot: Open Issue by Number"
      },
      {
        "command": "autobot.fetchIssue",
        "title": "AutoBot: Fetch Issue from GitHub"
      },
      {
        "command": "autobot.runPlanner",
        "title": "AutoBot: Run Planner"
      },
      {
        "command": "autobot.runPatcher",
        "title": "AutoBot: Run Patcher"
      },
      {
        "command": "autobot.runCritic",
        "title": "AutoBot: Run Critic"
      },
      {
        "command": "autobot.runPatchLoop",
        "title": "AutoBot: Run Planner → Patcher → Critic Loop"
      },
      {
        "command": "autobot.setGitHubToken",
        "title": "AutoBot: Set GitHub Token"
      },
      {
        "command": "autobot.showRepoIndex",
        "title": "AutoBot: Show Compact Repo Index"
      },
      {
        "command": "autobot.copyOpenLink",
        "title": "AutoBot: Copy Open-in-Editor Link (for Slack)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "autobot.patchView",
          "name": "AutoBot Patch",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "AutoBot",
      "properties": {
        "autobot.github.owner": {
          "type": "string",
          "default": "apache",
          "description": "GitHub repository owner (e.g. apache)."
        },
        "autobot.github.repo": {
          "type": "string",
          "default": "airflow",
          "description": "GitHub repository name."
        },
        "autobot.inference.baseUrl": {
          "type": "string",
          "default": "",
          "description": "Base URL for your API gateway in front of Vertex AI (e.g. https://autobot-api.run.app)."
        },
        "autobot.inference.apiKey": {
          "type": "string",
          "default": "",
          "description": "Optional Bearer token for your inference gateway (prefer Secret Storage for production)."
        },
        "autobot.inference.plannerPath": {
          "type": "string",
          "default": "/v1/planner",
          "description": "HTTP path for Planner inference."
        },
        "autobot.inference.patcherPath": {
          "type": "string",
          "default": "/v1/patcher",
          "description": "HTTP path for Patcher inference."
        },
        "autobot.inference.criticPath": {
          "type": "string",
          "default": "/v1/critic",
          "description": "HTTP path for Critic inference."
        },
        "autobot.inference.timeoutMs": {
          "type": "number",
          "default": 120000,
          "description": "Request timeout in milliseconds."
        },
        "autobot.patch.maxCriticIterations": {
          "type": "number",
          "default": 3,
          "description": "Maximum Patcher retries after REVISE from Critic."
        },
        "autobot.repoIndex.maxFiles": {
          "type": "number",
          "default": 400,
          "description": "Max files to include in compact repo index."
        },
        "autobot.repoIndex.maxDepth": {
          "type": "number",
          "default": 8,
          "description": "Max directory depth for repo walk."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
