# Copy to .env and fill in your values (do not commit .env)

# ── Recommended for development: Ollama (free, local, no tokens) ──────────────
# Pull model first: ollama pull qwen2.5-coder:7b
# Then run: ollama serve
AUTOBOT_MODE=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ── OR: Google AI Studio (Gemini Flash) ─────────────────────────────────────
# Get a free API key at https://aistudio.google.com/apikey
# Free tier: 15 RPM / 1M TPM / 1500 req/day with gemini-2.0-flash-lite
# gemini-2.5-flash is available with pay-as-you-go (very cheap ~$0.075/1M input tokens)
# Uncomment the 3 lines below and comment out the Ollama block above to switch.
# AUTOBOT_MODE=google_ai
# GOOGLE_API_KEY=your_key_here
# GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# ── OR: Vertex AI Gemini (GCP project) ──────────────────────────────────────
# Requires: gcloud auth application-default login
# AUTOBOT_MODE=vertex
# GCP_PROJECT_ID=your-project-id
# GCP_LOCATION=us-central1
# VERTEX_MODEL=gemini-2.5-flash

# ── GitHub (for live issue fetching) ────────────────────────────────────────
GITHUB_OWNER=apache
GITHUB_REPO=airflow
# Generate at https://github.com/settings/tokens (public_repo scope is enough)
# GITHUB_TOKEN=github_pat_...

# ── Pipeline Testing ─────────────────────────────────────────────────────────
# Stop the orchestrator early to inspect payloads without executing next steps.
# Options: "planner" (stops before patcher), "patcher" (stops before critic)
# AUTOBOT_STOP_AT=planner

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5000

# ── Tree-sitter index (for planner-orchestrator research loop) ──────────────
# Path to the pre-built tree-sitter index JSON from the indexing pipeline
# TS_INDEX_PATH=/path/to/tree_sitter/treesitter_index.json

# ── Neo4j / GraphRAG (for similar-issue search + co-modified files) ─────────
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASS=password

# ── HuggingFace TGI — LoRA Adapters (Planner / Patcher / Critic) ────────────
# Set AUTOBOT_MODE=hf_tgi and fill in your deployed TGI endpoint.
# Your single TGI instance serves all three adapters dynamically.
# AUTOBOT_MODE=hf_tgi
# HF_TGI_ENDPOINT=https://your-tgi-endpoint.endpoints.huggingface.cloud
# HF_TGI_TOKEN=hf_your_access_token_here
# HF_PLANNER_ADAPTER=shatayu1210/autobot-planner-lora
# HF_PATCHER_ADAPTER=shatayu1210/autobot-patcher-lora
# HF_CRITIC_ADAPTER=shatayu1210/autobot-critic-lora
