# ============================================================
# AutoBot — Unified Environment Configuration (TEMPLATE)
# ============================================================
# Copy to .env and fill in your secrets. Never commit .env.

# --- GitHub API ---
# GITHUB_APP_ID=your_github_app_id
# GITHUB_APP_INSTALLATION_ID=your_github_app_installation_id
# GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
GITHUB_TOKEN=your_github_token_here

# --- Snowflake ---
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=AIRFLOW_ML

# --- Airflow (docker-compose) ---
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=change_me

# --- OpenAI (labelling pipeline) ---
OPENAI_API_KEY=your_openai_key

# --- GCP/Vertex AI (optional) ---
# GCS_BUCKET=your_gcs_bucket
# GCS_PROJECT_ID=your_gcp_project_id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT_ID=autobot-demo-2
# GCP_LOCATION=us-central1
