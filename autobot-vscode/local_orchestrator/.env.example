# Copy to .env (do not commit .env)
# Project number 414904045328 is for console/billing; code uses project ID below.

GCP_PROJECT_ID=autobot-demo-2
# Use us-central1 for Gemini unless Console shows your model in another region (us-west1 often returns 404 for gemini-2.0-flash-001).
GCP_LOCATION=us-central1

# --- Pick ONE LLM mode: google_ai (API key) OR vertex (GCP) OR ollama ---

# Google AI Studio API key (no Vertex project): https://aistudio.google.com/apikey
AUTOBOT_MODE=google_ai
GOOGLE_API_KEY=your_key_here
# gemini-2.0-flash is not available to new API users; use 2.5.x or 1.5.x
GEMINI_MODEL=gemini-2.5-flash

# Vertex Gemini (AUTOBOT_MODE=vertex) — GenerativeModel + generateContent; gcloud auth application-default login
# VERTEX_MODEL=gemini-2.0-flash
# AUTOBOT_MODE=vertex

# Optional: live issue text from GitHub (apache/airflow)
GITHUB_OWNER=apache
GITHUB_REPO=airflow
# GITHUB_TOKEN=github_pat_...

# Ollama (AUTOBOT_MODE=ollama)
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2.5-coder:7b

# PORT=5000
